# Local Spring Boot datasource
DB_URL=jdbc:postgresql://localhost:5432/comic_reader
DB_USERNAME=comic_user
DB_PASSWORD=comic_pass

# Shared application settings
JWT_SECRET=CHANGE_THIS_SECRET_TO_A_LONG_RANDOM_STRING_1234567890ABCDEF
JWT_EXPIRATION_MS=86400000
UPLOAD_DIR=./uploads

# Docker Compose postgres service
POSTGRES_DB=comic_reader
POSTGRES_USER=comic_user
POSTGRES_PASSWORD=comic_pass

GEMINI_API_KEY=api-key

GOOGLE_CLIENT_ID=<WEB_CLIENT_ID>

# Translation provider routing
TRANSLATE_PROVIDER=gemini
TRANSLATE_FALLBACK_PROVIDER=none

# Local LLM (Ollama/OpenAI-compatible)
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=qwen2.5:1.5b
LOCAL_LLM_TIMEOUT_MS=30000

# Comic translate worker
TRANSLATION_WORKER_BASE_URL=http://localhost:8090
TRANSLATION_WORKER_TIMEOUT_MS=15000

# Piper TTS worker
TTS_WORKER_BASE_URL=http://localhost:8091
TTS_WORKER_TIMEOUT_MS=300000
TTS_WORKER_POLL_INTERVAL_MS=3000
TTS_WORKER_MAX_POLL_ATTEMPTS=60
TTS_DEFAULT_VOICE=vi_VN-vais1000-medium
TTS_DEFAULT_SPEED=1.0
TTS_DEFAULT_LANG=auto
