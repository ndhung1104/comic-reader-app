# Android emulator -> host machine backend
MOBILE_BASE_URL=http://10.0.2.2:8080/

# Public URL used for *shared links* (/share/...).
# For local testing where you copy the shared link into a PC browser or send it to another phone,
# set this to a reachable address (e.g. http://192.168.1.10:8080/).
# If omitted, it falls back to MOBILE_BASE_URL.
MOBILE_PUBLIC_BASE_URL=http://10.0.2.2:8080/

# Must be the *Web application* OAuth client id used for requestIdToken().
# Also ensure an *Android* OAuth client exists in the same Google Cloud project
# with package name `com.group09.ComicReader` and the correct SHA-1 (debug/release),
# otherwise Google Sign-In can fail with status code 10 (DEVELOPER_ERROR).
MOBILE_GOOGLE_WEB_CLIENT_ID=<WEB_CLIENT_ID>