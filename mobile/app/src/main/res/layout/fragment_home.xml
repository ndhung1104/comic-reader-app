<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_home_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/bg_top_bar_glass"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_home_menu"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_menu"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_home_search"
            app:layout_constraintStart_toEndOf="@id/img_home_menu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_home_search"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/nav_search"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_nav_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_home_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_home_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/browse_content_bottom_padding">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_home_hero"
                android:layout_width="0dp"
                android:layout_height="@dimen/home_hero_height"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardCornerRadius="@dimen/radius_xxl"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_home_hero_cover"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:contentDescription="@string/content_cover"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:srcCompat="@mipmap/ic_launcher" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/bg_gradient_hero"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_home_hero_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:background="@drawable/bg_genre_badge"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/spacing_xs"
                        android:text="@string/home_editor_choice"
                        android:textAllCaps="true"
                        android:textColor="@color/on_primary_container"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_home_hero_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/on_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tv_home_hero_meta"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Amber Protocol" />

                    <TextView
                        android:id="@+id/tv_home_hero_meta"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_sm"
                        app:layout_constraintBottom_toTopOf="@id/ll_home_hero_actions"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="4.9 - Action, Fantasy" />

                    <LinearLayout
                        android:id="@+id/ll_home_hero_actions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_home_hero_read"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height"
                            android:minWidth="@dimen/browse_filter_text_min_width"
                            android:text="@string/home_read_now"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="@dimen/radius_lg"
                            app:elevation="0dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_home_hero_details"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:minWidth="@dimen/browse_filter_text_min_width"
                            android:text="@string/home_details"
                            android:textSize="@dimen/text_sm"
                            app:cornerRadius="@dimen/radius_lg"
                            app:strokeColor="@color/surface_container_lowest"
                            app:strokeWidth="@dimen/stroke_thin" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_home_daily_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/home_new_updates"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv_home_daily_see_all"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_home_hero" />

            <TextView
                android:id="@+id/tv_home_daily_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/common_view_all"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/tv_home_daily_title"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_home_daily_list"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_xs"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_daily_title"
                tools:listitem="@layout/item_home_daily" />

            <TextView
                android:id="@+id/tv_home_trending_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/home_top_trending"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rcv_home_daily_list" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_home_trending_list"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_trending_title"
                tools:listitem="@layout/item_home_trending" />

            <TextView
                android:id="@+id/tv_home_recommended_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/home_recommended"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rcv_home_trending_list" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_home_recommended_list"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/spacing_xs"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_recommended_title"
                tools:listitem="@layout/item_home_recommended" />

            <TextView
                android:id="@+id/tv_home_genres_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/home_curated_genres"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rcv_home_recommended_list" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_home_genres"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_home_genres_title"
                app:spanCount="2"
                tools:listitem="@layout/item_genre" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
