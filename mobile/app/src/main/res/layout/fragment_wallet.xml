<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_wallet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_wallet_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_lg">

            <ImageButton
                android:id="@+id/btn_wallet_back"
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:background="@android:color/transparent"
                android:contentDescription="@string/content_back"
                android:src="@drawable/ic_arrow_back_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_wallet_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/wallet_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_wallet_back" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_wallet_balance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_wallet_title">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_balance_gradient"
                    android:padding="@dimen/spacing_xl">

                    <TextView
                        android:id="@+id/tv_wallet_balance_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_current_balance"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_wallet_balance_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_display"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_balance_label" />

                    <TextView
                        android:id="@+id/tv_wallet_coin_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="@string/wallet_coin_label"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_wallet_balance_value"
                        app:layout_constraintStart_toEndOf="@id/tv_wallet_balance_value" />

                    <TextView
                        android:id="@+id/tv_wallet_point_caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/wallet_point_label"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_balance_value" />

                    <TextView
                        android:id="@+id/tv_wallet_point_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_wallet_point_caption"
                        app:layout_constraintStart_toEndOf="@id/tv_wallet_point_caption" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_wallet_vip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_wallet_balance">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:id="@+id/tv_wallet_vip_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_vip_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_wallet_vip_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/wallet_vip_inactive"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_vip_title" />

                    <TextView
                        android:id="@+id/tv_wallet_vip_hint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/wallet_vip_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_vip_status" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wallet_vip_monthly"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/wallet_vip_monthly"
                        android:textSize="@dimen/text_sm"
                        app:cornerRadius="@dimen/radius_lg"
                        app:layout_constraintEnd_toStartOf="@id/btn_wallet_vip_yearly"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_vip_hint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wallet_vip_yearly"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/wallet_vip_yearly"
                        android:textSize="@dimen/text_sm"
                        app:cornerRadius="@dimen/radius_lg"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/btn_wallet_vip_monthly"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_vip_hint" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_wallet_rewards"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_wallet_vip">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:id="@+id/tv_wallet_rewards_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_reward_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_wallet_rewards_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/wallet_reward_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_rewards_title" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wallet_reward_coins"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/wallet_reward_coins"
                        android:textSize="@dimen/text_sm"
                        app:cornerRadius="@dimen/radius_lg"
                        app:layout_constraintEnd_toStartOf="@id/btn_wallet_reward_points"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_rewards_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_wallet_reward_points"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/wallet_reward_points"
                        android:textSize="@dimen/text_sm"
                        app:cornerRadius="@dimen/radius_lg"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/btn_wallet_reward_coins"
                        app:layout_constraintTop_toBottomOf="@id/tv_wallet_rewards_subtitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_wallet_package_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/wallet_packages"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_wallet_rewards" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_wallet_packages"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_wallet_package_title"
                app:spanCount="2" />

            <TextView
                android:id="@+id/tv_wallet_transaction_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/wallet_transactions"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rcv_wallet_packages" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_wallet_transactions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_xl"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_wallet_transaction_title" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
