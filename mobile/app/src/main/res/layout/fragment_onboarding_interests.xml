<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="@dimen/spacing_xxl"
    tools:context="com.group09.ComicReader.ui.onboarding.OnboardingInterestsFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sv_onboarding_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btn_onboarding_finish"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_onboarding_interests_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_interests_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_onboarding_interests_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/onboarding_interests_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md" />

            <TextView
                android:id="@+id/tv_onboarding_genre_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/onboarding_genres_selected_count"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                tools:text="Selected: 0" />

            <TextView
                android:id="@+id/tv_onboarding_genre_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/prg_onboarding_genres_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone"
                app:indicatorColor="@color/accent_primary" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_onboarding_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:singleSelection="false"
                app:chipSpacingHorizontal="@dimen/spacing_sm"
                app:chipSpacingVertical="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/tv_onboarding_art_style_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="@string/onboarding_art_style_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_onboarding_art_style_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/onboarding_art_style_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_onboarding_art_styles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:singleSelection="false"
                app:chipSpacingHorizontal="@dimen/spacing_sm"
                app:chipSpacingVertical="@dimen/spacing_sm" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_xxl" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_onboarding_finish"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:enabled="false"
        android:text="@string/onboarding_finish"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
