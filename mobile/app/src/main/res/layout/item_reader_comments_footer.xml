<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_reader_comments_footer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/tv_reader_comments_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/comic_comments"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_reader_comments_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/comment_empty"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_sm"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_reader_comments_title" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_reader_comments_content_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="rcv_reader_comments,tv_reader_comments_empty" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_reader_comments"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:nestedScrollingEnabled="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_reader_comments_title" />

    <TextView
        android:id="@+id/tv_reader_comments_see_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:padding="@dimen/spacing_sm"
        android:text="@string/comment_see_more"
        android:textColor="@color/accent_secondary"
        android:textSize="@dimen/text_sm"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/til_reader_comments_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrier_reader_comments_content_bottom" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_reader_comments_input"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:hint="@string/comment_hint"
        app:boxBackgroundColor="@color/bg_primary"
        app:boxStrokeColor="@color/divider_color"
        app:endIconDrawable="@drawable/ic_send_24"
        app:endIconMode="custom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_reader_comments_see_more">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edt_reader_comments_input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="@dimen/text_md" />

    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
