<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_search_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/bg_top_bar_glass"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_search_menu"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_menu"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_search_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/nav_search"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/img_search_action"
            app:layout_constraintStart_toEndOf="@id/img_search_menu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/img_search_action"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_filter"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_filter_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_search_query"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:hint="@string/search_hint"
        app:boxBackgroundColor="@color/surface_container_low"
        app:boxStrokeColor="@color/outline_variant"
        app:endIconDrawable="@drawable/ic_close_24"
        app:endIconMode="custom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_search_header"
        app:startIconDrawable="@drawable/ic_nav_search"
        app:startIconTint="@color/on_surface_variant">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edt_search_query"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:inputType="text"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant"
            android:textSize="@dimen/text_md" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_search_filters_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:text="@string/search_advanced_filters"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_search_query" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_search_filters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:chipSpacingHorizontal="@dimen/spacing_sm"
        app:chipSpacingVertical="@dimen/spacing_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_search_filters_title"
        app:singleSelection="true">

    </com.google.android.material.chip.ChipGroup>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_results_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cg_search_filters">

        <TextView
            android:id="@+id/tv_search_result_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_sm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ll_search_layout_toggle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="12 results found" />

        <LinearLayout
            android:id="@+id/ll_search_layout_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_search_grid"
                android:layout_width="@dimen/top_bar_action_size"
                android:layout_height="@dimen/top_bar_action_size"
                android:background="@drawable/bg_browse_header_icon"
                android:contentDescription="@string/search_featured_results"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_filter_24"
                app:tint="@color/primary" />

            <ImageView
                android:id="@+id/img_search_list"
                android:layout_width="@dimen/top_bar_action_size"
                android:layout_height="@dimen/top_bar_action_size"
                android:layout_marginStart="@dimen/spacing_xs"
                android:background="@drawable/bg_browse_header_icon"
                android:contentDescription="@string/search_featured_results"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_chevron_right_24"
                app:tint="@color/on_surface_variant" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/ll_search_pagination"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_search_results_header">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_search_prev"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reader_previous"
            android:layout_marginEnd="@dimen/spacing_md" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_search_pages"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_search_next"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reader_next" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_search_results"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/browse_content_bottom_padding"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_search_pagination"
        app:spanCount="2"
        tools:listitem="@layout/item_search_result" />

</androidx.constraintlayout.widget.ConstraintLayout>
