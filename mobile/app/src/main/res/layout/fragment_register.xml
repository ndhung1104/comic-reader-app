<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_register_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_register_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingTop="@dimen/spacing_xxxl"
            android:paddingEnd="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xxxl">

            <TextView
                android:id="@+id/tv_register_logo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/login_logo"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_display"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_register_tagline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center"
                android:text="@string/register_tagline"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_sm"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_register_logo" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_register_form"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="@dimen/auth_card_radius"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_register_tagline"
                app:strokeColor="@color/surface_container"
                app:strokeWidth="@dimen/stroke_thin">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:id="@+id/ll_register_tabs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_segment_container"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_xs"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_register_tab_login"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/browse_filter_button_height"
                            android:layout_weight="1"
                            android:text="@string/login_tab_login"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="@dimen/radius_md"
                            app:elevation="0dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_register_tab_signup"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/browse_filter_button_height"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:layout_weight="1"
                            android:text="@string/login_tab_signup"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@color/surface_container_highest"
                            app:cornerRadius="@dimen/radius_md"
                            app:elevation="0dp" />

                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_full_name"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:hint="@string/register_full_name_label"
                        app:boxBackgroundColor="@color/surface_container_low"
                        app:boxStrokeColor="@color/outline_variant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ll_register_tabs">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_register_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="textPersonName"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="@dimen/text_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_dob"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/register_dob_label"
                        app:boxBackgroundColor="@color/surface_container_low"
                        app:boxStrokeColor="@color/outline_variant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/til_register_full_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_register_dob"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="@dimen/text_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_email"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/login_email_label"
                        app:boxBackgroundColor="@color/surface_container_low"
                        app:boxStrokeColor="@color/outline_variant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/til_register_dob">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_register_email"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="@dimen/text_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_password"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/login_password_label"
                        app:boxBackgroundColor="@color/surface_container_low"
                        app:boxStrokeColor="@color/outline_variant"
                        app:endIconMode="password_toggle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/til_register_email">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_register_password"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="textPassword"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="@dimen/text_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_confirm_password"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/register_confirm_password_label"
                        app:boxBackgroundColor="@color/surface_container_low"
                        app:boxStrokeColor="@color/outline_variant"
                        app:endIconMode="password_toggle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/til_register_password">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_register_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="textPassword"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="@dimen/text_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_submit"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/register_button"
                        android:textSize="@dimen/text_md"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="@dimen/radius_lg"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/til_register_confirm_password" />

                    <TextView
                        android:id="@+id/tv_register_login"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:gravity="center"
                        android:text="@string/register_login_link"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btn_register_submit" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
