<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_home_trending_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_lg">

    <TextView
        android:id="@+id/tv_home_trending_rank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/outline_variant"
        android:textSize="@dimen/home_trending_rank_size"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="01" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_home_trending_cover"
        android:layout_width="@dimen/home_trending_cover_width"
        android:layout_height="@dimen/home_trending_cover_height"
        android:layout_marginStart="@dimen/spacing_md"
        android:contentDescription="@string/content_cover"
        android:scaleType="centerCrop"
        app:cornerSize="@dimen/radius_lg"
        app:layout_constraintStart_toEndOf="@id/tv_home_trending_rank"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/tv_home_trending_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_home_trending_cover"
        app:layout_constraintTop_toTopOf="@id/img_home_trending_cover"
        tools:text="Chronos Void" />

    <TextView
        android:id="@+id/tv_home_trending_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/on_surface_variant"
        android:textSize="@dimen/text_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_home_trending_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_home_trending_title"
        tools:text="Time is leaking. The only way to stop it..." />

    <LinearLayout
        android:id="@+id/ll_home_trending_genres"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@id/img_home_trending_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_home_trending_desc">

        <TextView
            android:id="@+id/tv_home_trending_genre1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_surface"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_xs"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="SCI-FI" />

        <TextView
            android:id="@+id/tv_home_trending_genre2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@drawable/bg_card_surface"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_xs"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="EPIC" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
