<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_ranking_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_ranking_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/bg_top_bar_glass"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_ranking_menu"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_menu"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_ranking_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:text="@string/ranking_leaderboard_title"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/img_ranking_search"
            app:layout_constraintStart_toEndOf="@id/img_ranking_menu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/img_ranking_search"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/nav_search"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_nav_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/ll_ranking_tabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:background="@drawable/bg_segment_container"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_xs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_ranking_header">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ranking_tab_top"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="@dimen/browse_filter_button_height"
            android:layout_weight="1"
            android:text="@string/ranking_tab_top_rated"
            android:textSize="@dimen/text_sm"
            app:backgroundTint="@color/surface_container_lowest"
            app:cornerRadius="@dimen/radius_md"
            app:elevation="0dp"
            app:icon="@drawable/ic_star_24"
            app:iconTint="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ranking_tab_view"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="@dimen/browse_filter_button_height"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_weight="1"
            android:text="@string/ranking_tab_most_viewed"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_sm"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="@dimen/radius_md"
            app:elevation="0dp"
            app:icon="@drawable/ic_eye_24"
            app:iconTint="@color/on_surface_variant" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_ranking_podium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_ranking_tabs">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ranking_podium_2"
            android:layout_width="0dp"
            android:layout_height="@dimen/ranking_podium_cover_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xs"
            app:cardBackgroundColor="@color/surface_container_highest"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/img_ranking_podium_cover_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/content_cover"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:srcCompat="@mipmap/ic_launcher" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_gradient_hero"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_ranking_podium_rank_2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:background="@drawable/bg_button_secondary"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_ranking_podium_title_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/tv_ranking_podium_rank_2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Title 2" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ranking_podium_1"
            android:layout_width="0dp"
            android:layout_height="@dimen/ranking_podium_center_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_xs"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:strokeColor="@color/tertiary"
            app:strokeWidth="@dimen/stroke_medium">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/img_ranking_podium_cover_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/content_cover"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:srcCompat="@mipmap/ic_launcher" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_gradient_hero"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:src="@drawable/ic_star_24"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/tertiary" />

                <TextView
                    android:id="@+id/tv_ranking_podium_rank_1"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:background="@drawable/bg_genre_badge"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/on_primary_container"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_ranking_podium_title_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/tv_ranking_podium_rank_1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Title 1" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ranking_podium_3"
            android:layout_width="0dp"
            android:layout_height="@dimen/ranking_podium_cover_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            app:cardBackgroundColor="@color/surface_container_highest"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/img_ranking_podium_cover_3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/content_cover"
                    android:scaleType="centerCrop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:srcCompat="@mipmap/ic_launcher" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_gradient_hero"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_ranking_podium_rank_3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/on_primary"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_ranking_podium_title_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/tv_ranking_podium_rank_3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:text="Title 3" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_ranking_list_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:text="@string/ranking_list_title"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_ranking_podium" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_ranking_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/browse_content_bottom_padding"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_ranking_list_title"
        tools:listitem="@layout/item_ranking" />

</androidx.constraintlayout.widget.ConstraintLayout>
