<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_ranking_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md">

    <TextView
        android:id="@+id/tv_ranking_number"
        android:layout_width="@dimen/ranking_number_min_width"
        android:layout_height="@dimen/ranking_list_cover_size"
        android:gravity="center"
        android:textColor="@color/outline_variant"
        android:textSize="@dimen/text_xl"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="#4" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_ranking_cover"
        android:layout_width="@dimen/ranking_list_cover_size"
        android:layout_height="@dimen/ranking_list_cover_size"
        android:layout_marginStart="@dimen/spacing_sm"
        android:contentDescription="@string/content_cover"
        android:scaleType="centerCrop"
        app:cornerSize="@dimen/radius_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_ranking_number"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/tv_ranking_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/img_ranking_trend"
        app:layout_constraintStart_toEndOf="@id/img_ranking_cover"
        app:layout_constraintTop_toTopOf="@id/img_ranking_cover"
        tools:text="Shadow Bound: Zero" />

    <TextView
        android:id="@+id/tv_ranking_author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/on_surface_variant"
        android:textSize="@dimen/text_xs"
        app:layout_constraintEnd_toStartOf="@id/img_ranking_trend"
        app:layout_constraintStart_toEndOf="@id/img_ranking_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_ranking_title"
        tools:text="Marcus Thorne" />

    <TextView
        android:id="@+id/tv_ranking_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:drawableEnd="@drawable/ic_star_24"
        android:drawablePadding="@dimen/spacing_xs"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_xs"
        app:layout_constraintStart_toEndOf="@id/img_ranking_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_ranking_author"
        tools:text="4.9" />

    <TextView
        android:id="@+id/tv_ranking_genres"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/on_surface_variant"
        android:textSize="@dimen/text_xs"
        app:layout_constraintBaseline_toBaselineOf="@id/tv_ranking_rating"
        app:layout_constraintEnd_toStartOf="@id/img_ranking_trend"
        app:layout_constraintStart_toEndOf="@id/tv_ranking_rating"
        tools:text="Action | 1.2M views" />

    <ImageView
        android:id="@+id/img_ranking_trend"
        android:layout_width="@dimen/icon_lg"
        android:layout_height="@dimen/icon_lg"
        android:layout_marginStart="@dimen/spacing_sm"
        android:contentDescription="@string/ranking_trending_up"
        android:src="@drawable/ic_arrow_forward_24"
        app:layout_constraintBottom_toBottomOf="@id/img_ranking_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/img_ranking_cover"
        app:tint="@color/primary" />

</androidx.constraintlayout.widget.ConstraintLayout>
