<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_library_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_library_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/bg_top_bar_glass"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_library_menu"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_menu"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_library_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/img_library_search"
            app:layout_constraintStart_toEndOf="@id/img_library_menu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/img_library_search"
            android:layout_width="@dimen/top_bar_action_size"
            android:layout_height="@dimen/top_bar_action_size"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/nav_search"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_nav_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_library_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:text="@string/library_title"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/text_display"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_library_header" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_library_filter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:background="@drawable/bg_segment_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_library_title"
        app:tabGravity="fill"
        app:tabIndicatorAnimationMode="elastic"
        app:tabIndicatorColor="@color/primary"
        app:tabIndicatorFullWidth="false"
        app:tabInlineLabel="false"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextAppearance="@style/TextAppearance.Material3.LabelLarge"
        app:tabTextColor="@color/on_surface_variant" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_library_recent_highlight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:cardBackgroundColor="@color/surface_container_highest"
        app:cardCornerRadius="@dimen/radius_xl"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_library_filter">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_library_highlight_cover"
                android:layout_width="@dimen/cover_detail_width"
                android:layout_height="@dimen/cover_detail_height"
                android:contentDescription="@string/content_cover"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:srcCompat="@mipmap/ic_launcher" />

                <TextView
                    android:id="@+id/tv_library_highlight_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_genre_badge"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_xs"
                    android:text="@string/library_highlight_progress"
                android:textColor="@color/on_primary_container"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_library_highlight_cover"
                app:layout_constraintTop_toTopOf="@id/img_library_highlight_cover" />

                <TextView
                    android:id="@+id/tv_library_highlight_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:maxLines="2"
                    android:text="@string/library_highlight_title"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_library_highlight_cover"
                app:layout_constraintTop_toBottomOf="@id/tv_library_highlight_badge" />

            <TextView
                android:id="@+id/tv_library_highlight_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:maxLines="2"
                android:text="@string/library_recent_history_subtitle"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_sm"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_library_highlight_cover"
                app:layout_constraintTop_toBottomOf="@id/tv_library_highlight_title" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_library_highlight_progress"
                android:layout_width="0dp"
                android:layout_height="@dimen/progress_height"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:indicatorColor="@color/primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_library_highlight_cover"
                app:layout_constraintTop_toBottomOf="@id/tv_library_highlight_subtitle"
                app:trackColor="@color/surface_container" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_library_continue_mock"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm"
                    android:text="@string/library_continue_reading"
                android:textSize="@dimen/text_sm"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/radius_lg"
                app:elevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_library_highlight_cover"
                app:layout_constraintTop_toBottomOf="@id/pb_library_highlight_progress" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_library_comics"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/browse_content_bottom_padding"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_library_recent_highlight"
        tools:listitem="@layout/item_library_comic" />

    <LinearLayout
        android:id="@+id/ll_library_empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rcv_library_comics"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/rcv_library_comics">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface_container"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_md"
                    android:src="@drawable/ic_nav_library"
                    app:tint="@color/primary" />

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_md"
                    android:src="@drawable/ic_eye_24"
                    app:tint="@color/tertiary" />

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_md"
                    android:src="@drawable/ic_star_24"
                    app:tint="@color/secondary" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_library_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/library_empty_title"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_library_empty_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:gravity="center"
            android:text="@string/library_empty_subtitle"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_sm" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
