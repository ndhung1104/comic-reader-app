<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_browse_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_browse_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@color/glass_overlay"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:elevation="@dimen/browse_header_elevation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_browse_menu"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/content_menu"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tv_browse_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_browse_search"
            app:layout_constraintStart_toEndOf="@id/img_browse_menu"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Kinetic Gallery" />

        <ImageView
            android:id="@+id/btn_browse_search"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:background="@drawable/bg_browse_header_icon"
            android:contentDescription="@string/nav_search"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_nav_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_browse_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_browse_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xxl"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingEnd="@dimen/spacing_xxl"
            android:paddingBottom="@dimen/browse_content_bottom_padding">

            <TextView
                android:id="@+id/tv_browse_discover_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/browse_discover_title"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/browse_discover_title_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_browse_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/browse_discover_subtitle"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_sm" />

            <LinearLayout
                android:id="@+id/ll_browse_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="vertical">

                <HorizontalScrollView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_browse_filter_group"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_xs">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_browse_filter_all"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/browse_filter_button_height"
                            android:minWidth="@dimen/browse_filter_all_min_width"
                            android:text="@string/browse_filter_all"
                            android:textAllCaps="false"
                            android:textColor="@color/on_primary"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="@dimen/radius_md"
                            app:elevation="0dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_browse_filter_completed"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/browse_filter_button_height"
                            android:minWidth="@dimen/browse_filter_text_min_width"
                            android:text="@string/browse_filter_completed"
                            android:textAllCaps="false"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="@dimen/radius_md"
                            app:elevation="0dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_browse_filter_ongoing"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/browse_filter_button_height"
                            android:minWidth="@dimen/browse_filter_text_min_width"
                            android:text="@string/browse_filter_ongoing"
                            android:textAllCaps="false"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_sm"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="@dimen/radius_md"
                            app:elevation="0dp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/browse_sort_by"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/browse_sort_label_size"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_browse_sort"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/browse_filter_button_height"
                        android:background="@drawable/bg_browse_sort_button"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="@dimen/browse_sort_min_width"
                        android:text="@string/browse_sort_popularity"
                        android:textAllCaps="false"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_sm"
                        app:icon="@drawable/ic_expand_more"
                        app:iconGravity="textEnd"
                        app:iconTint="@color/on_surface"
                        app:rippleColor="@color/surface_container_high" />

                </LinearLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_browse_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_xs"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
